{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/store/plugins",
      "destination": "/store-plugins"
    },
    {
      "source": "/store/conteudos",
      "destination": "/store-conteudos"
    },
    {
      "source": "/store/comunidade",
      "destination": "/store-comunidade"
    },
    {
      "source": "/plugins",
      "destination": "/store-plugins"
    },
    {
      "source": "/conteudos",
      "destination": "/store-conteudos"
    },
    {
      "source": "/comunidade",
      "destination": "/store-comunidade"
    },
    {
      "source": "/training",
      "destination": "/treinamento"
    },
    {
      "source": "/agentes-sistemas",
      "destination": "/agents-systems"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
